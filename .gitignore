# Environment — contains API keys, NEVER commit
backend/.env

# Python bytecode
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/**/*.pyc

# Virtual environment
backend/.venv/
backend/venv/

# uv lock (optional — uncomment to commit)
# backend/uv.lock

# Local vector store (large, regenerate with populate_precedents.py)
backend/data/chroma_db/

# Local analysis cache (auto-generated)
backend/data/analysis_cache/

# Scratch / temp files
backend/scratch/

