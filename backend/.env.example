# Copy this file to .env and fill in your keys
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
# Groq API key — free tier available at https://console.groq.com
GROQ_API_KEY=

# MongoDB connection string (local or Atlas)
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017

# ── Google Cloud (for OCR + Translation) ─────────────────────────────────────
# Only needed for scanned PDFs or non-English contracts
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Indian Kanoon API (for live precedent seeding) ────────────────────────────
# Get key at https://api.indiankanoon.org/
# Only needed to run scripts/populate_precedents_api.py
INDIAN_KANOON_API_KEY=
